# ─── App ───────────────────────────────────────────────
PORT=3000

# ─── Redis ─────────────────────────────────────────────
# Docker Compose: redis://redis:6379 | Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── Session ───────────────────────────────────────────
SESSION_TTL_SECONDS=3600
MAX_CONTEXT_TURNS=12

# ─── LLM (provider-agnostic, qua @earendil-works/pi-ai) ─
# LLM_PROVIDER = anthropic | openai
LLM_PROVIDER=anthropic
# Model id (pi-ai). Để trống → default: anthropic=claude-sonnet-4-6, openai=gpt-4o
LLM_MODEL=
# Bắt buộc nếu LLM_PROVIDER=anthropic (pi-ai đọc trực tiếp từ env này)
ANTHROPIC_API_KEY=
# Bắt buộc nếu LLM_PROVIDER=openai
OPENAI_API_KEY=

# ─── BurgerPrints API v2.0 ─────────────────────────────
BURGERPRINTS_API_BASE_URL=https://api.example.burgerprints.com/v2
BURGERPRINTS_API_KEY=
CATALOG_CACHE_TTL_SECONDS=300
