# ─── App ───────────────────────────────────────────────
PORT=3000

# ─── Redis ─────────────────────────────────────────────
# Docker Compose: redis://redis:6379 | Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── MongoDB ───────────────────────────────────────────
# Docker Compose: mongodb://mongo:27017/burgerprints | Local: mongodb://localhost:27017/burgerprints
MONGODB_URI=mongodb://localhost:27017/burgerprints

# ─── Auth / JWT ────────────────────────────────────────
JWT_SECRET=super-secret-key-change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Auth / Google OAuth (Optional) ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ─── Session ───────────────────────────────────────────
SESSION_TTL_SECONDS=3600
MAX_CONTEXT_TURNS=12

# ─── LLM (provider-agnostic, qua @earendil-works/pi-ai) ─
# LLM_PROVIDER = anthropic | openai
LLM_PROVIDER=anthropic
# Model id (pi-ai). Để trống → default: anthropic=claude-sonnet-4-5, openai=gpt-4o
LLM_MODEL=
# Bắt buộc nếu LLM_PROVIDER=anthropic (pi-ai đọc trực tiếp từ env này)
ANTHROPIC_API_KEY=
# Bắt buộc nếu LLM_PROVIDER=openai
OPENAI_API_KEY=
# (Tùy chọn) override endpoint OpenAI-compatible: proxy / Azure / OpenRouter / local
# vd https://openrouter.ai/api/v1 — để trống → dùng endpoint OpenAI mặc định
OPENAI_BASE_URL=

# ─── BurgerPrints API v2.0 ─────────────────────────────
BURGERPRINTS_API_BASE_URL=https://api.burgerprints.com/v2
# Lấy key: Fulfillment store → Settings → API Keys (BTC cấp)
BURGERPRINTS_API_KEY=
CATALOG_CACHE_TTL_SECONDS=300
